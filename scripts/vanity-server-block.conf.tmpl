# ══════════════════════════════════════════════════════════════════════════════
# Vanity domain server block — Phase 4.6.b
#
# Generated by scripts/provision-vanity-domain.sh — do not edit by hand.
# Substitutions: {{DOMAIN}}
#
# Customer domains serve the SPA directly. We don't replicate the marketing
# redirects from app.scaliyo.com (vanity domains are intended for the app
# experience only).
# ══════════════════════════════════════════════════════════════════════════════

# HTTP → HTTPS for the vanity domain.
# The /.well-known/acme-challenge/ path is handled by the default_server in
# /etc/nginx/sites-available/aurafunnel.conf — Let's Encrypt renewals work
# without us needing to expose the webroot here.
server {
    listen 80;
    listen [::]:80;
    server_name {{DOMAIN}};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{DOMAIN}};

    ssl_certificate     /etc/letsencrypt/live/{{DOMAIN}}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{DOMAIN}}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/scaliyo/current;
    index index.html;

    # Compression
    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_min_length 256;
    gzip_types text/plain text/css text/javascript application/javascript
               application/json application/xml application/wasm
               image/svg+xml font/woff2;

    # Aggressive caching for fingerprinted assets
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Send a Host hint to the SPA so it knows it's serving from a vanity
    # domain (the SPA can then look up workspace_branding accordingly).
    add_header X-Scaliyo-Vanity "{{DOMAIN}}" always;

    # SPA fall-through routing
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Defense in depth: never cache the index.html shell
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header X-Scaliyo-Vanity "{{DOMAIN}}" always;
        try_files /index.html =404;
    }
}
